generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  orderId      String     @id
  value        Float
  creationDate DateTime

  items        Items[]
}

model Items {
  orderId   String
  productId Int   @id
  quantity  Int
  price     Float

  order     Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@id([orderId, productId])
}